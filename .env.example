# PostgreSQL connection string (required)
DATABASE_URL=postgresql://postgres:password@localhost:5432/agents_mcp

# Base directory where project clones live
PROJECTS_BASE_DIR=/home/user/projects

# Max number of tasks run concurrently by the scheduler (default 5)
MAX_CONCURRENT_TASKS=5

# Hard timeout per task in milliseconds; the process is SIGTERM'd then SIGKILL'd (default 1800000 = 30 min)
TASK_TIMEOUT_MS=1800000

# Prefix prepended to every task prompt. Use omc commands to delegate, e.g. "/ultrawork " or "/team " (default "/goal ")
GOAL_PREFIX=/goal

# Claude Code binary to invoke (default "claude")
CC_BIN=claude

# Extra args appended to the Claude Code invocation, space-separated (default empty)
CC_EXTRA_ARGS=

# Whether to auto-create a branch + PR when a task produces file changes (default true; set to "false" to disable)
AUTO_PR=true

# Base branch for auto-PRs. If unset, the project's current branch is detected at task start.
# BASE_BRANCH=main

# Max bytes of diff patch stored in task results before truncation (default 200000)
MAX_PATCH_BYTES=200000
